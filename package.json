{
  "name": "DataMind",
  "version": "1.2.6",
  "description": "DataMind - 支持多数据源连接和自然语言查询的智能数据分析平台",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch --include src --include modules src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:prod": "npm run build && cd admin-ui && npm run build",
    "start": "node dist/src/index.js",
    "start:secure": "tsx scripts/start-secure.ts",
    "encrypt-env": "tsx scripts/encrypt-env.ts",
    "module:create": "tsx src/module-system/cli/index.ts create",
    "module:validate": "tsx src/module-system/cli/index.ts validate",
    "module:test": "tsx src/module-system/cli/index.ts test",
    "module:build": "tsx src/module-system/cli/index.ts build",
    "test": "tsx tests/run-tests.ts",
    "test:api": "tsx tests/run-tests.ts",
    "test:unit": "vitest run",
    "test:modules": "vitest run tests/modules",
    "test:compat": "vitest run tests/compat",
    "test:core": "vitest run tests/core",
    "test:platform": "vitest run tests/module-system tests/security",
    "test:menu-smoke": "tsx scripts/smoke-menu-routes.ts",
    "test:menu-smoke:auto": "tsx scripts/smoke-menu-routes.ts --ensure-services",
    "test:business-smoke": "tsx scripts/smoke-business-flows.ts",
    "test:business-smoke:auto": "tsx scripts/smoke-business-flows.ts --ensure-services",
    "test:scenarios": "vitest run tests/admin/aiDiagnosis.test.ts tests/admin/crawlerTemplateMigration.test.ts tests/admin/dataPreview.test.ts tests/admin/selectorValidation.test.ts tests/admin/templateTest.test.ts",
    "deploy": "./deploy.sh",
    "docker:build": "docker build -t DataMind .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f app",
    "test:province": "tsx scripts/test-provinces.ts",
    "test:provinces": "tsx scripts/test-provinces.ts",
    "test:all": "tsx scripts/test-provinces.ts all",
    "test:dynamic": "tsx scripts/test-provinces.ts dynamic",
    "crawler:clean": "tsx scripts/crawler-clean.ts",
    "bootstrap:templates": "tsx scripts/bootstrap-crawler-templates.ts init",
    "bootstrap:clone": "tsx scripts/bootstrap-crawler-templates.ts clone"
  },
  "dependencies": {
    "@types/multer": "^2.0.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.2",
    "docx": "^9.6.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "mysql2": "^3.6.5",
    "openai": "^4.20.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.3",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.36.1",
    "sm-crypto": "^0.4.0",
    "sql-formatter": "^15.7.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.10.9",
    "@types/semver": "^7.7.1",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^4.0.17",
    "fast-check": "^4.5.3",
    "playwright": "^1.59.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.17"
  }
}
